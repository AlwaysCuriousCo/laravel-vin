{
    "name": "alwayscurious/laravel-vin",
    "description": "Decode US vehicle VINs into year, make, model and more via the NHTSA vPIC API.",
    "keywords": [
        "laravel",
        "vin",
        "nhtsa",
        "vpic",
        "vehicle",
        "automotive",
        "vin-decoder"
    ],
    "homepage": "https://github.com/alwayscurious/laravel-vin",
    "license": "MIT",
    "authors": [
        {
            "name": "Always Curious",
            "email": "tim@alwayscurious.co",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "AlwaysCurious\\Vin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlwaysCurious\\Vin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlwaysCurious\\Vin\\VinServiceProvider"
            ],
            "aliases": {
                "Vin": "AlwaysCurious\\Vin\\Facades\\Vin"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
